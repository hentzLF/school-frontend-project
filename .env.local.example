# AgriMarket Frontend — environment variables
#
# Copy this file to `.env.local` and adjust the values for your environment:
#   cp .env.local.example .env.local
#
# `.env.local` is git-ignored and must never be committed.

# Base URL of the AgriMarket ASP.NET Core backend API.
# All backend calls are proxied through the Next.js Route Handlers in
# `src/app/api/`, so this is a SERVER-SIDE only variable — it is never
# bundled into client-side code and is never exposed to the browser.
#
# Local development (backend running on the host):
BACKEND_URL=http://localhost:5047
#
# Docker / docker-compose (backend reachable from the container):
# BACKEND_URL=http://host.docker.internal:5047
